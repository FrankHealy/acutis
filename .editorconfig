root = true

############################
# Global defaults
############################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

############################
# C# / .NET
############################
[*.cs]
indent_size = 4

[*.csproj]
indent_size = 2

[*.sln]
indent_style = tab

############################
# TypeScript / JavaScript
############################
[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

############################
# JSON / Config
############################
[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

############################
# Markdown
############################
[*.md]
trim_trailing_whitespace = false
