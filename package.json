{
  "name": "acutis",
  "private": true,
  "workspaces": [
    "acutis.centre/acutis.centre.web",
    "acutis.centre/acutis.centre.tab",
    "apps/*-web",
    "apps/*-mobile",
    "acutis.shared/acutis.shared.web/packages/*",
    "acutis.shared/acutis.shared.tab/packages/*",
    "acutis.shared/acutis.shared.api/packages/*",
    "acutis.shared/acutis.shared.resources/packages/*"
  ],
  "scripts": {
    "web": "npm --prefix acutis.centre/acutis.centre.web run dev",
    "api": "dotnet watch --project acutis.centre/acutis.centre.api/src/Acutis.Api run",
    "mob": "powershell -NoProfile -Command \"Set-Location 'acutis.mob'; npm run start\"",
    "dev": "npm run web",
    "build:centre-web": "npm --workspace acutis.web run build",
    "build:practitioner-web": "npm --workspace @acutis/practitioner-web run build",
    "build:community-web": "npm --workspace @acutis/community-web run build",
    "build:outreach-web": "npm --workspace @acutis/outreach-web run build",
    "typecheck:shared": "npm run typecheck --workspaces --if-present",
    "test:shared": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:all": "npm run lint"
  },
  "dependencies": {
    "expo": "^55.0.9"
  }
}
