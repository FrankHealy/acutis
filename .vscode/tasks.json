{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Web: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/acutis.centre/acutis.centre.web" },
      "problemMatcher": []
    },
    {
      "label": "Web: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/acutis.centre/acutis.centre.web" },
      "isBackground": true,
      "problemMatcher": []
    },

    {
      "label": "API: restore",
      "type": "shell",
      "command": "dotnet restore",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "API: watch",
      "type": "shell",
      "command": "dotnet watch run --project acutis.centre/acutis.centre.api/src/Acutis.Api/Acutis.Api.csproj",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },

    {
      "label": "Mobile: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/acutis.centre/acutis.centre.tab" },
      "problemMatcher": []
    },
    {
      "label": "Mobile: start",
      "type": "shell",
      "command": "npx expo start",
      "options": { "cwd": "${workspaceFolder}/acutis.centre/acutis.centre.tab" },
      "isBackground": true,
      "problemMatcher": []
    },

    {
      "label": "Dev: all (api + web + mob)",
      "dependsOrder": "parallel",
      "dependsOn": ["API: watch", "Web: dev", "Mobile: start"],
      "problemMatcher": []
    }
  ]
}
