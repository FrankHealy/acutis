# Copy this file to deploy/.env and fill in real values before using docker compose.

# Shared network that already contains the existing SQL Server and Keycloak containers.
DOCKER_SHARED_NETWORK=acutis-platform

# Published host ports for initial testing.
API_PORT=5000
WEB_PORT=3000

# API container settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
Hosting__DisableHttpsRedirection=true
Database__ApplyMigrationsOnStartup=false

# SQL Server connection string.
# Use the Docker-internal SQL hostname already used on the VPS, for example sqlserver or acutis-sql.
ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=Acutis;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True;

# Keycloak / JWT settings for the API.
# Use the real issuer URL used by the tokens in production.
Jwt__Authority=https://keycloak.example.com/realms/AcutisRealm
Jwt__Issuer=https://keycloak.example.com/realms/AcutisRealm
Jwt__Audience=api-client

# API CORS configuration for the web origin(s).
Cors__Origins__0=http://localhost:3000

# Web container settings
# INTERNAL_API_BASE_URL is used server-side inside the web container.
INTERNAL_API_BASE_URL=http://api:5000
# NEXT_PUBLIC_API_BASE_URL is used by the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# NextAuth / Keycloak settings for the web app.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ID=web-client
AUTH_KEYCLOAK_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ISSUER=https://keycloak.example.com/realms/AcutisRealm

# Keep authentication enabled by default.
NEXT_PUBLIC_DISABLE_AUTH=false
