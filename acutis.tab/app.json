{
  "expo": {
    "name": "Acutis",
    "slug": "acutis-tab",
    "scheme": "acutis-tab",
    "icon": "./assets/icon.png",
    "platforms": [
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "androidSpeechServicePackages": [
            "com.google.android.as",
            "com.google.android.tts",
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Acutis Tablet to attach admission photos.",
          "cameraPermission": "Allow Acutis Tablet to capture admission photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "apiBaseUrl": "https://acutis.salientrecovery.com/api-proxy",
      "keycloak": {
        "baseUrl": "https://acutis.salientrecovery.com/keycloak",
        "issuer": "https://acutis.salientrecovery.com/keycloak/realms/acutisrealm",
        "authUrl": "https://acutis.salientrecovery.com/keycloak/realms/acutisrealm/protocol/openid-connect/auth",
        "clientId": "tab-client",
        "audience": "api-client",
        "redirectUri": "acutis-tab://redirect"
      },
      "development": {
        "authorizationDisabled": false
      },
      "security": {
        "requireHardwareBackedKeystore": true
      },
      "eas": {
        "projectId": "b5f5142e-085e-4803-b48a-e4fd3e53a80d"
      }
    },
    "android": {
      "package": "com.salientrecovery.acutis.tab",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#023C69"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    }
  }
}
