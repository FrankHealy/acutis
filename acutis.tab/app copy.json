{
  "expo": {
    "name": "acutis.tab",
    "slug": "acutis-tab",
    "version": "0.1.0",
    "scheme": "acutis-tab",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.acutis.tab"
    },
    "android": {
      "package": "com.acutis.tab",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "enabled": true
        }
      ],
      [
        "expo-secure-store",
        {
          "ignoreDeviceProfile": false
        }
      ],
      "expo-router",
      "expo-localization"
    ],
    "extra": {
      "apiBaseUrl": "https://api.acutis.local",
      "keycloak": {
        "issuer": "https://keycloak.acutis.local/auth/realms/acutis",
        "clientId": "tab-client",
        "redirectUri": "acutis-tab://redirect"
      }
    }
  }
}
